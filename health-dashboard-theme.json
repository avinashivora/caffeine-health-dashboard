            "fontFamily": "Segoe UI"
          }
        ],
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#6F4E37" } }
          }
        ],
        "dataLabels": [
          {
            "show": false,
            "color": { "solid": { "color": "#FAF7F2" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },

    "filledMap": {
      "*": {
        "legend": [
          {
            "show": true,
            "position": "Top",
            "fontColor": { "solid": { "color": "#2C1A0E" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "dataLabels": [
          {
            "show": false,
            "color": { "solid": { "color": "#FAF7F2" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },

    "esriArcGISMaps": {
      "*": {
        "legend": [
          {
            "show": true,
            "fontSize": 10,
            "fontFamily": "Segoe UI",
            "fontColor": { "solid": { "color": "#2C1A0E" } }
          }
        ],
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#6F4E37" } }
          }
        ]
      }
    },

    "shape": {
      "*": {
        "line": [
          {
            "lineColor": { "solid": { "color": "#6F4E37" } },
            "transparency": 0,
            "weight": 1
          }
        ],
        "fill": [
          {
            "show": true,
            "fillColor": { "solid": { "color": "#EDE5DA" } },
            "transparency": 0
          }
        ]
      }
    },

    "image": {
      "*": {
        "imageScaling": [{ "imageScalingType": "Fit" }]
      }
    },

    "textbox": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FAF7F2" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false,
            "color": { "solid": { "color": "#E0D5C8" } }
          }
        ]
      }
    }
  }
}
